cmd/swe-swe/dockerless-payload/bin/linux-*/
tmp/
/.swe-swe/
/swe-swe/
/.claude/
.playwright-mcp/
.cache/
!cmd/swe-swe/templates/container/.swe-swe/
!cmd/swe-swe/testdata/golden/**/.swe-swe/
!cmd/swe-swe/testdata/golden/**/.claude/

# Generated from .txt files for local dev (make run)
cmd/swe-swe/templates/host/swe-swe-server/go.mod
cmd/swe-swe/templates/host/swe-swe-server/go.sum
cmd/swe-swe/templates/host/swe-swe-server/container-templates/
.test-repos/

# Packer build artifacts
deploy/digitalocean/manifest.json

# Local dev artifacts
.aider.*
.test-home*

# Worktree symlinks
.claude
# ...but track the dev-only commands (everything else under .claude stays ignored).
# These are flat (no swe-swe/ subdir) so they surface as /reboot etc., visibly
# distinct from the shipped /swe-swe:* bundle.
!.claude/
.claude/*
!.claude/commands/
.claude/commands/*
!.claude/commands/reboot.md
!.claude/commands/reboot-light.md
!.claude/commands/test-full-e2e.md
!.claude/commands/wrap-up.md
.playwright-mcp
.test-repos
tools/

# local tooling
.pi/
