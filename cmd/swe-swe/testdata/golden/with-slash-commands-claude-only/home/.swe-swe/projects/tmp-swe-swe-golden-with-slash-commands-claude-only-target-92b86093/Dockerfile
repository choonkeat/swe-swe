# swe-swe development environment
# Based on golang image with Node.js and AI assistant tools
# Generated by: swe-swe init

# Stage 1: Build swe-swe-server from source
FROM golang:1.24-alpine AS server-builder
WORKDIR /build
COPY swe-swe-server/go.mod swe-swe-server/go.sum ./
RUN go mod download
COPY swe-swe-server/*.go ./
COPY swe-swe-server/agent-chat-dist/ ./agent-chat-dist/
COPY swe-swe-server/static/ ./static/
COPY swe-swe-server/page-templates/ ./page-templates/
COPY swe-swe-server/container-templates/ ./container-templates/
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o swe-swe-server .

# Build mcp-lazy-init (generic lazy-init MCP proxy, stdlib only)
COPY mcp-lazy-init/main.go /build-mcp-lazy-init/main.go
RUN cd /build-mcp-lazy-init && go mod init mcp-lazy-init && CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /build-mcp-lazy-init/mcp-lazy-init .

# Stage 2: Main development environment
FROM golang:1.24-bookworm

# Install base dependencies
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    git \
    build-essential \
    ca-certificates \
    file \
    jq \
    less \
    lsof \
    unzip \
    vim \
    && rm -rf /var/lib/apt/lists/*

# Ensure consistent UTF-8 locale across all sessions
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8


# Install Node.js 24 LTS from NodeSource (Debian repos only have EOL Node.js 18)
RUN curl -fsSL https://deb.nodesource.com/setup_24.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

# Ensure npm global packages are in PATH
ENV PATH="/usr/local/lib/node_modules/.bin:${PATH}"


# Install browser automation dependencies (Chromium, Xvfb, x11vnc, noVNC)
# Each session gets its own Xvfb display, Chromium instance, and VNC server
RUN apt-get update && apt-get install -y --no-install-recommends \
    chromium \
    xvfb \
    x11vnc \
    novnc \
    websockify \
    && rm -rf /var/lib/apt/lists/*

# Override default noVNC viewer with custom version (adds View only / Interactive toggle)
COPY swe-swe-server/static/vnc_lite.html /usr/share/novnc/vnc_lite.html

# Install Tailscale (static binaries, no apt repo).  Dormant unless
# TS_AUTHKEY is set at runtime; see www/swe-swe-tailscale.md.
RUN curl -fsSL https://tailscale.com/install.sh | sh

# Pre-create the default tailscale state directory and hand ownership to the
# app user.  Without this, tailscaled bootstrapping fails with "permission
# denied" the first time TS_AUTHKEY is set, because /var/lib/tailscale is
# created by the tailscale package owned by root.  Users who mount a PaaS
# volume at this path still get their volume's contents (the mount shadows
# the baked-in dir).
RUN mkdir -p /var/lib/tailscale && \
    chown 1000:1000 /var/lib/tailscale && \
    chmod 700 /var/lib/tailscale


# Install Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code



# Install MCP Playwright for browser automation
# This enables the system to control browsers via Playwright CDP connections
RUN npm install -g @playwright/mcp







# Clone slash commands repositories to temp location
# (will be copied to home directory by entrypoint.sh)
RUN git clone --depth 1 https://github.com/choonkeat/slash-commands.git /tmp/slash-commands/ck

# Enterprise certificate support
# swe-swe init detects NODE_EXTRA_CA_CERTS/SSL_CERT_FILE env vars and copies certs
# to .swe-swe/certs/. The entrypoint.sh installs them into the system trust store.

# Copy swe-swe-server and mcp-lazy-init binaries from builder stage
COPY --from=server-builder /build/swe-swe-server /usr/local/bin/swe-swe-server
COPY --from=server-builder /build-mcp-lazy-init/mcp-lazy-init /usr/local/bin/mcp-lazy-init

# Copy entrypoint script
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# Create non-root user for running swe-swe-server
# If target GID already exists (e.g., dialout=20), use that group; otherwise create app group
# Use -K to suppress warnings about macOS UIDs (501+) being below Linux UID_MIN (1000)
RUN if ! getent group 1000 > /dev/null; then groupadd -K GID_MIN=20 -g 1000 app; fi && \
    useradd -m -K UID_MIN=100 -u 1000 -g 1000 -s /bin/bash app

# Minimal shell prompt: just current directory basename + $
RUN echo "PS1='\\W\\$ '" >> /etc/bash.bashrc

# Prepend proxy + bin dirs to PATH.
# - /workspace/.swe-swe/proxy: project-tier `swe-swe proxy <cmd>` scripts
#   (host writes them; container sees them via the /workspace bind mount).
# - /home/app/.swe-swe/proxy: global-tier `swe-swe proxy --global <cmd>` scripts
#   (host writes them to ${HOME}/.swe-swe/proxy; sub-mount makes them visible here).
# - /home/app/.swe-swe/bin:   stack shims (xdg-open, goose wrapper, etc.).
# Order matters: project tier > global tier > shims, so the most specific wins.
# Uses /etc/profile.d/ so login shells (terminal, codex) pick it up
# after /etc/profile resets PATH.
RUN echo 'export PATH="/workspace/.swe-swe/proxy:/home/app/.swe-swe/proxy:/home/app/.swe-swe/bin:$PATH"' > /etc/profile.d/swe-swe-path.sh

# Auto-load per-workspace env from $PWD/.swe-swe/env at login time.
# Login shells (e.g. the right-side "Terminal" tab Shell session, which runs
# `bash -l`) source /etc/profile, which resets PATH to the Debian default.
# That clobbers any PATH override that swe-swe-server already injected via
# the .swe-swe/env file. Re-applying it here, after swe-swe-path.sh and after
# /etc/profile's PATH reset, makes user PATH overrides survive in login shells.
# The `zz-` prefix ensures this runs last in /etc/profile.d/, so user values
# can prepend onto everything else.
# NOTE: this file is sourced by bash, so values containing spaces or shell
# metacharacters must be quoted (e.g. MSG="hello world"). swe-swe-server's
# Go-side loadEnvFile uses a dumber KEY=VALUE parser; for portability, keep
# .swe-swe/env contents to simple `KEY=value` and `KEY=$OTHER:value` forms.
RUN printf '%s\n' \
    'if [ -f "$PWD/.swe-swe/env" ]; then' \
    '    set -a' \
    '    . "$PWD/.swe-swe/env"' \
    '    set +a' \
    'fi' > /etc/profile.d/zz-swe-swe-env.sh

# Run as non-root user (entrypoint handles setup without privilege escalation)
USER app
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

# Default working directory (entrypoint will cd to /workspace for the server)
WORKDIR /workspace

# Environment variables for dockerfile-only mode
ENV SWE_PORT=1977
ENV SWE_SWE_PASSWORD=changeme

EXPOSE ${SWE_PORT:-1977}

# Default command: run swe-swe-server pointing to /workspace
CMD ["/usr/local/bin/swe-swe-server", "-working-directory", "/workspace", "-addr", "0.0.0.0:${SWE_PORT:-1977}"]
